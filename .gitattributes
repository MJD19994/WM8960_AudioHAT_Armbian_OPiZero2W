# Force LF line endings for files used in Linux environments
*           text=auto eol=lf

# Explicitly mark text file types
*.sh        text eol=lf
*.service   text eol=lf
*.conf      text eol=lf
*.rules     text eol=lf
*.dts       text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.c         text eol=lf
*.h         text eol=lf
Makefile    text eol=lf

# Binary files — no line ending conversion
*.dtb       binary
*.xz        binary
*.gz        binary
*.png       binary
*.jpg       binary
